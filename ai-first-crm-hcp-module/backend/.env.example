# Database Configuration
DATABASE_URL=mysql+mysqlconnector://root:password@localhost:3306/ai_first_crm
TEST_DATABASE_URL=mysql+mysqlconnector://root:password@localhost:3306/ai_first_crm_test

# Application Configuration
APP_NAME=AI First CRM HCP Module
APP_VERSION=1.0.0
DEBUG=True
SECRET_KEY=your-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30

# CORS Configuration
# Space-separated list of allowed origins
CORS_ORIGINS=http://localhost:3000 http://127.0.0.1:3000

# Server Configuration
HOST=0.0.0.0
PORT=8000

# Groq AI Configuration
GROQ_API_KEY=your-groq-api-key-here
GROQ_MODEL=gemma2-9b-it
